# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Miner backend URL
MINER_API_URL=http://localhost:8091

# xAI Grok API key (for /memory AI chat — get one at console.x.ai)
XAI_API_KEY=

# Arweave wallet JWK — generate locally, never share or request over HTTP:
#   node -e "require('arweave').init({}).wallets.generate().then(k => console.log(JSON.stringify(k)))"
# Fund the returned address with AR before enabling uploads.
ARWEAVE_ENV=mainnet
ARWEAVE_KEY=

# Admin bearer token for sensitive routes (e.g. GET /api/arweave/wallet).
# Fail-closed: if unset, those routes reject ALL requests with 401.
# Generate a strong token: openssl rand -hex 32
ENGRAM_ADMIN_TOKEN=
